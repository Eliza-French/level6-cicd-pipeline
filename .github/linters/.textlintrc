{
  "//": "Config for super-linter's bundled textlint. We keep the default",
  "//1": "terminology rule (which enforces 'repository' over 'repo', 'GitHub'",
  "//2": "over 'github', etc.) but exclude the bare word 'url' because the",
  "//3": "Liquid template on the homepage — `{{ post.url }}` — is Jekyll's",
  "//4": "canonical lowercase attribute name that we cannot rename.",
  "rules": {
    "terminology": {
      "defaultTerms": true,
      "exclude": ["url"]
    }
  }
}
